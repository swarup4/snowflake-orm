{
  "name": "snowflake-orm",
  "version": "2.0.0",
  "description": "snowflake-orm is a ORM for NodeJS & Snowflake DB",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "test": "node --test test/sql-builder.test.js test/integration.test.js test/live.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swarup4/snowflake-orm.git"
  },
  "keywords": [
    "Node JS",
    "Snowflake DB",
    "orm",
    "object relational mapper",
    "sql",
    "snowflake orm",
    "model"
  ],
  "author": "Swarup Saha",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/swarup4/snowflake-orm/issues"
  },
  "homepage": "https://github.com/swarup4/snowflake-orm#readme",
  "dependencies": {
    "snowflake-sdk": "^2.4.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
